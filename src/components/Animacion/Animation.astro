---
import Presentation from "@components/Animacion/components/Presentacion.astro";
import LogoLGsus from "@@/LogoLGsus.webp";
import Fondo from "@@/fondo.webp";
---

<div
  id="logo-mask"
  class="w-full h-screen flex justify-center items-center fixed"
>
  <div
    id="animation-contener"
    class="size-full flex justify-center items-center scale-115 top-0 z-50"
  >
    <img
      id="logo-animation"
      src={LogoLGsus.src}
      alt="logo"
      class="absolute z-20 w-60 top-16 drop-shadow-sm drop-shadow-cyan-500"
    />
    <div
      id="info-animation"
      class="w-2/3 h-auto overflow-hidden absolute border border-blue-700/25 bg-sky-300/30 backdrop-blur-xs [box-shadow:inset_0_0_5px_3px_rgba(0,0,0,0.4),0_0_20px_rgba(0,0,0,0.2)] p-10 rounded-2xl"
    >
      <Presentation />
    </div>
    <img
      id="bg-animation"
      src={Fondo.src}
      alt="jesus"
      class="size-full object-cover"
    />
  </div>
</div>

<script>
  import { initAnimationLogo } from "@/typescript/animation-logo";
  initAnimationLogo();
</script>
